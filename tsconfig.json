{
  "compilerOptions": {
    "target": "ES2020",
    "sourceMap": true,
    "module": "ES2020",
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "moduleResolution": "node",
    "outDir": "libs",
    "jsx": "preserve",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "resolveJsonModule": true
  },
  "ts-node": {
    "esm": true
  },
  "include": [
    "./src/**/*",
    "./test/**/*",
    "shared",
    "pages",
    "components"
, "legacy/Members.tsx", "legacy/Members.tsx", "legacy/NewProposalDialog.tsx", "legacy/NewTaskDialog.tsx", "legacy/Orders.tsx", "legacy/PeerPicker.tsx", "legacy/Proposal.tsx", "legacy/Publicity.tsx", "legacy/Solution.tsx", "legacy/Title.tsx", "legacy/types.ts", "legacy/utils.ts", "legacy/WindowTimePicker.tsx", "legacy/constant.ts", "legacy/constant.ts", "legacy/Dashboard.tsx", "legacy/DomainPicker.tsx", "legacy/Domains.tsx", "legacy/DomainsStack.tsx", "legacy/global.d.ts"  ],
  "exclude": [
    "node_modules"
  ]
}
